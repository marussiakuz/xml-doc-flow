    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="cf:docDetailsWithExpirationDateAndDocChangeDate">
        <xs:sequence>
          <xs:element name="name" type="bt:notEmptyString">
            <xs:annotation>
              <xs:documentation>Наименование документа</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="documentType">
            <xs:annotation>
              <xs:documentation>Вид документа</xs:documentation>
            </xs:annotation>
            <xs:simpleType>
              <xs:restriction base="bt:notEmptyString">
                <xs:enumeration value="Правоустанавливающие документы на земельный участок ( в том числе соглашение об установлении сервитута, решение об установлении публичного сервитута, схема расположения земельного участка на кадастровом плане)" />
                <xs:enumeration value="Правоустанавливающие документы на земельный участок правообладателя, с которым заключено соглашение о передаче" />
                <xs:enumeration value="Утвержденный проект межевания территории" />
                <xs:enumeration value="Схема расположения земельного участка на кадастровом плане" />
                <xs:enumeration value="ГПЗУ" />
                <xs:enumeration value="Результаты инженерных изысканий" />
                <xs:enumeration value="Пояснительная записка" />
                <xs:enumeration value="Схема планировочной организации земельного участка, выполненная в соответствии с информацией, указанной в градостроительном плане земельного участка" />
                <xs:enumeration value="Разделы, содержащие архитектурные и конструктивные решения, а также решения и мероприятия, направленные на обеспечение доступа инвалидов к объекту капитального строительства" />
                <xs:enumeration value="Проект организации строительства объекта капитального строительства (включая проект организации работ по сносу объектов капитального строительства, их частей в случае необходимости сноса объектов капитального строительства, их частей для строительства, реконструкции других объектов капитального строительства)" />
                <xs:enumeration value="Положительное заключение экспертизы проектной документации" />
                <xs:enumeration value="Разрешение на отклонение от предельных параметров разрешенного строительства, реконструкции" />
