                <xs:sequence>
                  <xs:element name="relatedDocsId" type="bt:GUID">
                    <xs:annotation>
                      <xs:documentation>ID связанного документа</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="idMCHDList" minOccurs="0">
                    <xs:annotation>
                      <xs:documentation>Список единых регистрационных номеров доверенности (МЧД)</xs:documentation>
                    </xs:annotation>
                    <xs:complexType>
                      <xs:sequence>
                        <xs:element name="idMCHD" type="bt:GUID" maxOccurs="unbounded">
                          <xs:annotation>
                            <xs:documentation>
                              Единый регистрационный номер доверенности (МЧД)
                              Заполняется данными МЧД всех подписантов в случае, если передаётся файл pdf акта подписанный внутренними подписями подписантов
                            </xs:documentation>
                          </xs:annotation>
                        </xs:element>
                      </xs:sequence>
                    </xs:complexType>
                  </xs:element>
                </xs:sequence>
              </xs:complexType>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="senderId" type="bt:GUID">
        <xs:annotation>
          <xs:documentation>
            ID отправителя
            Идентификатор Представителя Участника, кто совершал последнее действие и передает документ на следующее действие (шаг маршрута)
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="receiverId" type="bt:GUID" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            ID получателя
            Идентификатор Представителя Участника, кому передается документ на следующее действие (шаг маршрута)
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="approversList" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Список согласующих для документа ИД</xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element name="approversListItem" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>Согласующий для документа ИД</xs:documentation>
              </xs:annotation>
              <xs:complexType>
                <xs:sequence>
                  <xs:element name="participantId" type="bt:GUID">
                    <xs:annotation>
                      <xs:documentation>ID участника</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="employeesList">
                    <xs:annotation>
                      <xs:documentation>
                        Список сотрудников организации, участвующих в согласовании комплекта
                      </xs:documentation>
                    </xs:annotation>
                    <xs:complexType>
                      <xs:sequence>
                        <xs:element name="employeesListItem" maxOccurs="unbounded">
                          <xs:annotation>
                            <xs:documentation>
                              Сотрудник организации, участвующий в согласовании комплекта
                            </xs:documentation>
                          </xs:annotation>
                          <xs:complexType>
                            <xs:sequence>
                              <xs:element name="employeeId" type="bt:GUID">
                                <xs:annotation>
                                  <xs:documentation>ID представителя</xs:documentation>
                                </xs:annotation>
                              </xs:element>
                              <xs:element name="resolution" type="bt:notEmptyString">
                                <xs:annotation>
                                  <xs:documentation>Резолюция сотрудника</xs:documentation>
                                </xs:annotation>
                              </xs:element>
                            </xs:sequence>
                          </xs:complexType>
                        </xs:element>
                      </xs:sequence>
                    </xs:complexType>
                  </xs:element>
                </xs:sequence>
              </xs:complexType>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

