          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="relatedDocsIdsList" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Список ID связанных документов</xs:documentation>
        </xs:annotation>
