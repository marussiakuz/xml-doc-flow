<?xml version="1.0" encoding="utf-8" ?>
<xs:schema targetNamespace="http://types/CommonTypes.xsd"
  elementFormDefault="qualified"
  xmlns:xs="http://www.w3.org/2001/XMLSchema"
  xmlns:cf="http://types/CommonTypes.xsd"
  xmlns:bt="http://types/BaseTypes.xsd"
  xmlns:bd="http://types/BaseDocument.xsd"
  xmlns:sg="http://www.w3.org/2000/09/xmldsig#"
>
  <!-- Импорты внешних зависимостей -->
  <xs:import schemaLocation="./BaseTypes.xsd" namespace="http://types/BaseTypes.xsd" />
  <xs:import schemaLocation="./BaseDocument.xsd" namespace="http://types/BaseDocument.xsd" />
  <xs:import schemaLocation="Xmldsig.xsd" namespace="http://www.w3.org/2000/09/xmldsig#" />

  <!-- Типы и группы, содержащие информацию о подписи и ее атрибутах (start) -->
  <xs:complexType name="signature">
    <xs:annotation>
      <xs:documentation>Подпись (УКЭП)</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element ref="sg:Signature">
        <xs:annotation>
          <xs:documentation>Параметры УКЭП</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="personId" type="bt:GUID">
        <xs:annotation>
          <xs:documentation>Id подписанта</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="mchdId" type="bt:GUID" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Единый регистрационный номер доверенности (МЧД)</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="attachedDocuments">
    <xs:annotation>
      <xs:documentation>Документ с внутренней и/или откреплённой подписью</xs:documentation>
    </xs:annotation>
    <xs:choice>
      <xs:element name="variantRequiredFileWithInternalSignature">
        <xs:annotation>
          <xs:documentation>
            Вариант с обязательным элементом "Документ с внутренней подписью"
          </xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element name="fileWithInternalSignature" type="cf:fileWithInternalSignature">
              <xs:annotation>
                <xs:documentation>
                  Документ с внутренней подписью
                  Заполняется в случаях, если передается:
                  1. файл документа, подписанный внутренними подписями
                  2. файл копии документа заверенная ("копия верна") внутренней подписью
                </xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="fileWithDisattachSignature" type="cf:fileWithDisattachSignature" minOccurs="0">
              <xs:annotation>
                <xs:documentation>
                  Документ с откреплённой подписью / Документ без подписей
                  Заполняется в случае:
                  1. если документ подписан  открепленной подписью и передается  файл документа
                  и файлы(.sig) открепленных подписей  подписантов
                  2. если файл передаваемого документа не требует подписания
                </xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="variantRequiredFileWithDisattachSignature">
        <xs:annotation>
          <xs:documentation>
            Вариант с обязательным элементом "Документ с откреплённой подписью / Документ без подписей"
          </xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element name="fileWithDisattachSignature" type="cf:fileWithDisattachSignature">
              <xs:annotation>
                <xs:documentation>
                  Документ с откреплённой подписью / Документ без подписей
                  Заполняется в случае:
                  1. если документ подписан  открепленной подписью и передается  файл документа
                  и файлы(.sig) открепленных подписей  подписантов
                  2. если файл передаваемого документа не требует подписания
                </xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
    </xs:choice>
  </xs:complexType>

  <xs:complexType name="fileWithInternalSignature">
    <xs:annotation>
      <xs:documentation>Документ с внутренней подписью</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="file" type="cf:attachedFile">
        <xs:annotation>
          <xs:documentation>Файл в хранилище</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="personsWithMchdList" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            Подписант + МЧД (список)
            Заполняется в случае, если документ подписан внутренними подписями ФЛ (не руководитель) и/или подписант в проекте является представителем одного из участников ЖЦ ОКС 
          </xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element name="personsWithMchd" type="cf:personIdAndMchd" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>Подписант + МЧД (элемент списка)</xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="personIdAndMchd">
    <xs:annotation>
      <xs:documentation>Подписант + МЧД</xs:documentation>
    </xs:annotation>
    <xs:choice>
      <xs:element name="variantRequiredPersonId">
        <xs:annotation>
          <xs:documentation>
            Вариант с обязательным элементом "ID подписанта"
          </xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element name="personId" type="bt:GUID">
              <xs:annotation>
                <xs:documentation>
                  ID подписанта
                  - Заполняется в случае, если подписант в проекте является представителем одного из участников ЖЦ ОКС
                  - Не заполняется, если подписантом является внешний по отношению к проекту ЮЛ или ФЛ  
                </xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="personMchd" type="cf:personMchd" minOccurs="0">
              <xs:annotation>
                <xs:documentation>
                  МЧД подписанта
                  Заполняется в случае, если документ подписан подписантом подписью ФЛ (не руководитель)  
                </xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="variantRequiredPersonMchd">
        <xs:annotation>
          <xs:documentation>
            Вариант с обязательным элементом "МЧД подписанта"
          </xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element name="personMchd" type="cf:personMchd">
              <xs:annotation>
                <xs:documentation>
                  МЧД подписанта
                  Заполняется в случае, если документ подписан подписантом подписью ФЛ (не руководитель)  
                </xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
    </xs:choice>
  </xs:complexType>

  <xs:complexType name="personIdAndMchdAndSignatureFile">
    <xs:annotation>
      <xs:documentation>Подписант (ID) + подпись + МЧД</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="cf:personIdAndMchd">
        <xs:sequence>
          <xs:element name="signatureFile" type="cf:attachedFile">
            <xs:annotation>
              <xs:documentation>
                Подпись подписанта (откреплённая)
                Заполняется информацией о загруженном в ФХ файле открепленной подписи.  
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="fileWithDisattachSignature">
    <xs:annotation>
      <xs:documentation>Документ с откреплённой подписью / Документ без подписей</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="file" type="cf:attachedFile">
        <xs:annotation>
          <xs:documentation>Файл в хранилище</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="personsWithMchdAndSignatureList" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Подписант + подпись + МЧД (список)</xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element
              name="personsWithMchdAndSignature"
              type="cf:personIdAndMchdAndSignatureFile"
              maxOccurs="unbounded"
            >
              <xs:annotation>
                <xs:documentation>Подписант + подпись + МЧД (элемент списка)</xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="disattachOrInternalSignatures">
    <xs:annotation>
      <xs:documentation>Внутренняя или откреплённая подпись</xs:documentation>
    </xs:annotation>
    <xs:choice>
      <xs:element name="personsWithMchdAndSignatureList">
        <xs:annotation>
          <xs:documentation>Подписант + подпись + МЧД (список)</xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element
              name="personsWithMchdAndSignature"
              type="cf:personIdAndMchdAndSignatureFile"
              maxOccurs="unbounded"
            >
              <xs:annotation>
                <xs:documentation>Подписант + подпись + МЧД (элемент списка)</xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="personsWithMchdList">
        <xs:annotation>
          <xs:documentation>
            Подписант + МЧД (список)
            Заполняется в случае, если документ подписан внутренними подписями ФЛ (не руководитель) и/или подписант в проекте является представителем одного из участников ЖЦ ОКС 
          </xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element name="personsWithMchd" type="cf:personIdAndMchd" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>Подписант + МЧД (элемент списка)</xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
    </xs:choice>
  </xs:complexType>

  <xs:complexType name="personMchd">
    <xs:annotation>
      <xs:documentation>МЧД подписанта</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="mchdId" type="bt:GUID">
        <xs:annotation>
          <xs:documentation>Единый регистрационный номер доверенности (МЧД)</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="principalInn" type="bt:inn">
        <xs:annotation>
          <xs:documentation>ИНН доверителя</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="representativeInn" type="bt:inn" minOccurs="0">
        <xs:annotation>
          <xs:documentation>ИНН представителя</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="signatureAndFullName">
    <xs:annotation>
      <xs:documentation>Подпись и атрибуты подписи (ФИО)</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element ref="sg:Signature">
        <xs:annotation>
          <xs:documentation>Параметры УКЭП</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="signatureAttributesFullName" type="cf:fullName">
        <xs:annotation>
          <xs:documentation>Атрибуты подписи (ФИО)</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="signatureAndRepresentative">
    <xs:annotation>
      <xs:documentation>
        Подпись и атрибуты подписи (ФИО и должность подписанта)
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element ref="sg:Signature">
        <xs:annotation>
          <xs:documentation>Параметры УКЭП</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="signatureAttributesRepresentative" type="cf:representative">
        <xs:annotation>
          <xs:documentation>Атрибуты подписи (ФИО и должность подписанта)</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>
  <!-- Типы и группы, содержащие информацию о подписи и ее атрибутах (end) -->

  <!-- Типы и группы, содержащие информацию о человеке (представителе) (start) -->
  <xs:group name="fullNameGroup">
    <xs:annotation>
      <xs:documentation>Группа, содержащая фамилию, имя и отчество</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="lastName" type="bt:notEmptyString">
        <xs:annotation>
          <xs:documentation>Фамилия</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="firstName" type="bt:notEmptyString">
        <xs:annotation>
          <xs:documentation>Имя</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="middleName" type="bt:notEmptyString" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Отчество</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:group>

  <xs:complexType name="fullName">
    <xs:annotation>
      <xs:documentation>ФИО</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:group ref="cf:fullNameGroup" />
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="representative">
    <xs:annotation>
      <xs:documentation>
        Информация о представителе (ФИО, должность)
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:group ref="cf:fullNameGroup">
        <xs:annotation>
          <xs:documentation>ФИО</xs:documentation>
        </xs:annotation>
      </xs:group>
      <xs:element name="position" type="bt:notEmptyString">
        <xs:annotation>
          <xs:documentation>Должность</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="representativeWithId">
    <xs:annotation>
      <xs:documentation>
        Информация о представителе (ФИО, должность, ID представителя)
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="cf:representative">
        <xs:sequence>
          <xs:element name="personId" type="bt:GUID">
            <xs:annotation>
              <xs:documentation>ID представителя</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="representativeWithOptionalId">
    <xs:annotation>
      <xs:documentation>
        Информация о представителе (ФИО, должность, ID представителя)
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="cf:representative">
        <xs:sequence>
          <xs:element name="personId" type="bt:GUID" minOccurs="0">
            <xs:annotation>
              <xs:documentation>ID представителя</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="representativeWithIdAndIDNR">
    <xs:annotation>
      <xs:documentation>
        Информация о представителе (ФИО, должность, ID представителя, идентификационный номер в национальном реестре специалистов в области строительства)
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="cf:representativeWithId">
        <xs:sequence>
          <xs:element name="specialistIdNumber" type="bt:notEmptyString" minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                Идентификационный номер в национальном реестре специалистов в области строительства
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="representativeWithAdminDoc">
    <xs:annotation>
      <xs:documentation>
        Информация о представителе (ФИО, должность, распорядительный документ, подтверждающий полномочия (включая дату документа))
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="cf:representative">
        <xs:sequence>
          <xs:element name="administrativeDocument" type="cf:docNameAndNumberAndDate">
            <xs:annotation>
              <xs:documentation>Распорядительный документ, подтверждающий полномочия</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="representativeWithAdminDocAndOrgName">
    <xs:annotation>
      <xs:documentation>
        Информация о представителе (ФИО, должность, наименование организации распорядительный документ, подтверждающий полномочия (включая дату документа))
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="cf:representative">
        <xs:sequence>
          <xs:element name="organizationName" type="bt:notEmptyString">
            <xs:annotation>
              <xs:documentation>Наименование организации</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="administrativeDocument" type="cf:docNameAndNumberAndDate">
            <xs:annotation>
              <xs:documentation>Распорядительный документ, подтверждающий полномочия</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="representativeWithOptionalAdminDoc">
    <xs:annotation>
      <xs:documentation>
        Информация о представителе (ФИО, должность, распорядительный документ, подтверждающий полномочия (включая дату документа) (необяз.))
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="cf:representative">
        <xs:sequence>
          <xs:element name="administrativeDocument" type="cf:docNameAndNumberAndDate" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Распорядительный документ, подтверждающий полномочия (необяз.)</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="representativeWithAdminDocAndIDNR">
    <xs:annotation>
      <xs:documentation>
        Информация о представителе (ФИО, должность, распорядительный документ, подтверждающий полномочия (включая дату документа), идентификационный номер в национальном реестре специалистов в области строительства)
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="cf:representativeWithAdminDoc">
        <xs:sequence>
          <xs:element name="specialistIdNumber" type="bt:notEmptyString">
            <xs:annotation>
              <xs:documentation>Идентификационный номер специалиста</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="representativeWithDate">
    <xs:annotation>
      <xs:documentation>Информация о представителе (ФИО, должность, дата)</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="cf:representative">
        <xs:sequence>
          <xs:element name="date" type="xs:date">
            <xs:annotation>
              <xs:documentation>Дата</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="representativeWithOrganizationName">
    <xs:annotation>
      <xs:documentation>Информация о представителе (ФИО, должность, наименование организации)</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="cf:representative">
        <xs:sequence>
          <xs:element name="organizationName" type="bt:notEmptyString">
            <xs:annotation>
              <xs:documentation>Наименование организации</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="representativeWithOrganizationNameAndId">
    <xs:annotation>
      <xs:documentation>
        Информация о представителе (ФИО, должность, наименование организации, ID представителя)
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="cf:representative">
        <xs:sequence>
          <xs:element name="organizationName" type="bt:notEmptyString">
            <xs:annotation>
              <xs:documentation>Наименование организации</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="personId" type="bt:GUID">
            <xs:annotation>
              <xs:documentation>ID представителя</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="representativeWithOrgNameAndRepresentationDocId">
    <xs:annotation>
      <xs:documentation>
        Информация о представителе (ФИО, должность, наименование организации, ID документа о представительстве)
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
