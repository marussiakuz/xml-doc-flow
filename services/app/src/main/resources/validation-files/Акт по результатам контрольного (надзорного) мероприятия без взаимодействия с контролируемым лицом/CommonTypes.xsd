                </xs:annotation>
              </xs:element>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
        <xs:element name="number" type="bt:notEmptyString">
          <xs:annotation>
            <xs:documentation>Номер документа без структурной разбивки</xs:documentation>
          </xs:annotation>
        </xs:element>
      </xs:choice>
