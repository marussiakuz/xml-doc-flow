    <xs:annotation>
      <xs:documentation>
        Реквизиты документа для актов
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="name" type="bt:notEmptyString">
        <xs:annotation>
          <xs:documentation>Наименование документа</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="docId" type="bt:GUID">
        <xs:annotation>
          <xs:documentation>id документа ИД</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:choice>
        <xs:element name="structureElementNumber">
          <xs:annotation>
            <xs:documentation>
              Составной номер документа
            </xs:documentation>
          </xs:annotation>
          <xs:complexType>
            <xs:sequence>
              <xs:element name="actSequenceNumber" type="xs:positiveInteger">
                <xs:annotation>
                  <xs:documentation>Порядковый номер акта внутри структурного элемента ИД</xs:documentation>
                </xs:annotation>
              </xs:element>
              <xs:element name="workDocSectionId" type="bt:notEmptyString" minOccurs="0">
                <xs:annotation>
                  <xs:documentation>Буквенное обозначение структурного элемента ИД, равного разделу РД</xs:documentation>
                </xs:annotation>
              </xs:element>
              <xs:element name="constructionObjId" type="bt:notEmptyString" minOccurs="0">
                <xs:annotation>
                  <xs:documentation>
                    Буквенное обозначение структурного элемента ИД, равного какому-либо структурному элементу объекта строительства (конструкции, сооружению и т.д.)
