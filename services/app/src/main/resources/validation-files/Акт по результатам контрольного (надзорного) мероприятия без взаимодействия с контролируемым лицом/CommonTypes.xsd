  <xs:complexType name="workOrTestInfo">
    <xs:annotation>
      <xs:documentation>
        Информация о работе / испытании, выполняемой(-ом) в процессе строительства/реконструкции/капитального ремонта объекта капитального строительства
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="cf:hiddenWorkInfo">
        <xs:sequence>
          <xs:element name="location" type="cf:location">
            <xs:annotation>
              <xs:documentation>Местоположение</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="qualityAssuranceRecordId" type="bt:GUID" minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                Идентификатор записи в спецжурнале работ или иного документа, подтверждающего качество
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="attestationInfo">
    <xs:annotation>
      <xs:documentation>Информация о прохождении аттестации</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="attestationResult" type="bt:notEmptyString">
        <xs:annotation>
          <xs:documentation>Отметка о прохождении аттестации</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="attestationDate" type="xs:date">
        <xs:annotation>
          <xs:documentation>Дата аттестации</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="datetimeInterval">
    <xs:annotation>
      <xs:documentation>
        Временной интервал (дата и время начала, дата и время окончания)
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="beginDate" type="xs:dateTime">
        <xs:annotation>
          <xs:documentation>Дата и время начала</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="endDate" type="xs:dateTime">
        <xs:annotation>
          <xs:documentation>Дата и время окончания</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="dateInterval">
    <xs:annotation>
      <xs:documentation>
        Временной интервал (дата начала, дата окончания)
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="beginDate" type="xs:date">
        <xs:annotation>
          <xs:documentation>Дата начала</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="endDate" type="xs:date">
        <xs:annotation>
          <xs:documentation>Дата окончания</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="timeInterval">
    <xs:annotation>
      <xs:documentation>
        Временной интервал (время начала, время окончания)
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="beginTime" type="xs:time">
        <xs:annotation>
          <xs:documentation>Время начала</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="endTime" type="xs:time">
        <xs:annotation>
          <xs:documentation>Время окончания</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="timeIntervalWithDuration">
    <xs:annotation>
      <xs:documentation>
        Временной интервал (время начала, время окончания) с продолжительностью
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="cf:timeInterval">
        <xs:sequence>
          <xs:element name="duration" type="xs:time">
            <xs:annotation>
              <xs:documentation>Продолжительность (время)</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="dateAndShiftInfo">
    <xs:annotation>
      <xs:documentation>Информация о дате и смене</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="date" type="xs:date">
        <xs:annotation>
          <xs:documentation>дата</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="shift" type="bt:notEmptyString">
        <xs:annotation>
          <xs:documentation>смена</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="hiddenWorkInfo">
    <xs:annotation>
      <xs:documentation>Тип, содержащий в себе описание работы</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="workId" type="bt:GUID" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Id работы</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="workName" type="bt:notEmptyString">
        <xs:annotation>
          <xs:documentation>Наименование работы</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="constructionStructureElement" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            Структурный элемент здания, строения или сооружения
          </xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element name="structureElementId" type="bt:GUID" minOccurs="0">
              <xs:annotation>
                <xs:documentation>Id структурного элемента</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="structureElementName" type="bt:notEmptyString">
              <xs:annotation>
                <xs:documentation>Наименование структурного элемента здания, строения или сооружения</xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="workMethodsList" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Методы выполнения работы</xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element name="workMethodsListItem" type="bt:notEmptyString" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>Метод выполнения работы</xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="hiddenWork">
    <xs:annotation>
      <xs:documentation>Тип, содержащий в себе информацию о скрытой работе</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="hiddenWorkInfo" type="cf:hiddenWorkInfo">
        <xs:annotation>
          <xs:documentation>Описание скрытой работы</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="location" type="cf:location">
        <xs:annotation>
          <xs:documentation>Место выполнения скрытой работы</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="documentInfo" type="cf:actRequisites">
        <xs:annotation>
          <xs:documentation>Параметры документа, в котором описана скрытая работа</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="permanentObjectInfo">
    <xs:annotation>
      <xs:documentation>
        Тип, содержащий в себе информацию об объекте капитального строительства
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="permanentObjectName" type="bt:notEmptyString">
        <xs:annotation>
          <xs:documentation>Наименование объекта (этапа)</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="permanentObjectAddress" type="cf:postalOrConstructionSiteAddress">
        <xs:annotation>
          <xs:documentation>Информация об адресе объекта (Почтовом или строительном)</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="permanentObjectId" type="bt:GUID">
        <xs:annotation>
          <xs:documentation>id объекта капитального строительства</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="governmentRegulationPermanentObjectType">
    <xs:annotation>
      <xs:documentation>Наименование вида ОКС по ПП РФ от 16.02.2008 г. №87</xs:documentation>
    </xs:annotation>
    <xs:choice>
      <xs:element name="industrialFacility">
        <xs:annotation>
          <xs:documentation>
            Объект производственного назначения, не являющийся линейным объектом
            (в качестве значения элемента укажите любую непустую строку)
          </xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:simpleContent>
            <xs:extension base="bt:notEmptyString">
              <xs:attribute name="permanentObjectCode" type="bt:notEmptyString" use="optional">
                <xs:annotation>
                  <xs:documentation>Код вида ОКС по приказу от 02.11.2022 г. N 928/пр</xs:documentation>
                </xs:annotation>
              </xs:attribute>
            </xs:extension>
          </xs:simpleContent>
        </xs:complexType>
      </xs:element>
      <xs:element name="nonIndustrialFacility">
        <xs:annotation>
          <xs:documentation>
            Объект непроизводственного назначения
            (в качестве значения элемента укажите любую непустую строку)
          </xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:simpleContent>
            <xs:extension base="bt:notEmptyString">
              <xs:attribute name="permanentObjectCode" type="bt:notEmptyString" use="required">
                <xs:annotation>
                  <xs:documentation>Код вида ОКС по приказу от 02.11.2022 г. N 928/пр</xs:documentation>
                </xs:annotation>
              </xs:attribute>
            </xs:extension>
          </xs:simpleContent>
        </xs:complexType>
      </xs:element>
      <xs:element name="linearTypeFacility">
        <xs:annotation>
          <xs:documentation>
            Линейный объект
            (в качестве значения элемента укажите любую непустую строку)
          </xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:simpleContent>
            <xs:extension base="bt:notEmptyString">
              <xs:attribute name="permanentObjectCode" type="bt:notEmptyString" use="optional">
                <xs:annotation>
                  <xs:documentation>Код вида ОКС по приказу от 02.11.2022 г. N 928/пр</xs:documentation>
                </xs:annotation>
              </xs:attribute>
            </xs:extension>
          </xs:simpleContent>
        </xs:complexType>
      </xs:element>
    </xs:choice>
  </xs:complexType>

  <xs:complexType name="bimConfigurableSection">
    <xs:annotation>
      <xs:documentation>Моделируемый раздел (подраздел) ЦИМ ОКС</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="bimElementsList">
        <xs:annotation>
          <xs:documentation>Список элементов ЦИМ ОКС</xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element name="bimElement" type="cf:bimElement" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>Элемент ЦИМ (ОКС)</xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="bimSectionCode" type="bt:notEmptyString">
        <xs:annotation>
          <xs:documentation>Шифр раздела (подраздела) ЦИМ</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="bimElement">
    <xs:annotation>
      <xs:documentation>Элемент ЦИМ (ОКС)</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="elementName" type="bt:notEmptyString">
        <xs:annotation>
          <xs:documentation>
            Наименование элемента
            (Значения закладываются справочником в соответствии с методикой по разработке ТЗ на ЦИМ)
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="bimElementAttributeGroupsList">
        <xs:annotation>
          <xs:documentation>
            Список подгрупп атрибутов элемента ЦИМ ОКС
            (cодержит в себе сведения об обязательных и дополнительных подгруппах атрибутов, которые указываются для элемента ЦИМ ОКС)
          </xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element name="bimElementAttributeGroup" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>Подгруппа атрибутов элемента ЦИМ ОКС</xs:documentation>
              </xs:annotation>
              <xs:complexType>
                <xs:sequence>
                  <xs:element name="groupName" type="bt:notEmptyString">
                    <xs:annotation>
                      <xs:documentation>Наименование подгруппы атрибутов элемента ЦИМ ОКС</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="bimElementAttributesList">
                    <xs:annotation>
                      <xs:documentation>Список атрибутов элемента ЦИМ ОКС указанной подгруппы</xs:documentation>
                    </xs:annotation>
                    <xs:complexType>
                      <xs:sequence>
                        <xs:element name="bimElementAttribute" type="cf:bimElementAttribute" maxOccurs="unbounded">
                          <xs:annotation>
                            <xs:documentation>Атрибут элемента ЦИМ ОКС</xs:documentation>
                          </xs:annotation>
                        </xs:element>
                      </xs:sequence>
                    </xs:complexType>
                  </xs:element>
                </xs:sequence>
              </xs:complexType>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="ifcCode" type="bt:notEmptyString">
        <xs:annotation>
          <xs:documentation>
            Класс IFC
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ksiCode" type="bt:notEmptyString" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            Код КСИ
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="msskCode" type="bt:notEmptyString" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            Код МССК
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="comment" type="bt:notEmptyString" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Комментарий</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="additionalBimElement">
    <xs:annotation>
      <xs:documentation>Дополнительный элемент раздела (подраздела) ЦИМ</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="cf:bimElement">
        <xs:sequence>
          <xs:element name="elementName" type="bt:notEmptyString">
            <xs:annotation>
              <xs:documentation>
                Наименование элемента
                (Принимает значения в соответствии с методикой формирования ТЗ ЦИМ)
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="bimElementAttribute">
    <xs:annotation>
      <xs:documentation>
        Атрибут элемента ЦИМ ОКС
        (характеристика массива атрибутивных данных)
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="ifcCode" type="bt:notEmptyString">
        <xs:annotation>
          <xs:documentation>Код подгруппы (IFC)</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ifcAttributeName" type="bt:notEmptyString">
        <xs:annotation>
          <xs:documentation>
            Наименование характеристики
            (Основной атрибут по указанию необходимого атрибута)
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="attributeName" type="bt:notEmptyString" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            Наименование атрибута
            (не обязательно, т.к. может отсутствовать в отличии от наименования атрибута IFC)
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="attributeType" type="bt:notEmptyString">
        <xs:annotation>
          <xs:documentation>Тип атрибутивных данных</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="unit" type="bt:notEmptyString" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Единица измерения</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="specAttributeName" type="bt:notEmptyString" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Наименование атрибута (проприетарный формат)</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="exampleRecord" type="bt:notEmptyString" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Пример записи характеристики</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="bimSectionIdentifyingInfo">
    <xs:annotation>
      <xs:documentation>
        Идентифицирующая информация раздела/подраздела элементов ЦИМ ОКС
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="name" type="bt:notEmptyString">
        <xs:annotation>
          <xs:documentation>
            Наименование раздела/подраздела элементов ЦИМ ОКС
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="code" type="bt:notEmptyString">
        <xs:annotation>
          <xs:documentation>
            Шифр раздела/подраздела элементов ЦИМ ОКС
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="bimSection">
    <xs:annotation>
      <xs:documentation>Раздел, к которому относится элемент ЦИМ ОКС</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="cf:bimSectionIdentifyingInfo">
        <xs:sequence>
          <xs:element name="bimSubsection" type="cf:bimSectionIdentifyingInfo" minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                Подраздел, к которому относится элемент
                (Обязательно, если раздел дополнительно разделяется на подразделы)
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="collisionMatrixElement">
    <xs:annotation>
      <xs:documentation>Элемент матрицы коллизий</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="bimSection" type="cf:bimSection">
        <xs:annotation>
          <xs:documentation>Раздел, к которому относится элемент ЦИМ ОКС</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="elementType" type="bt:notEmptyString" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            Тип элемента
            - в рамках раздела/подраздела типы элементов не могут повторяться
            - в случае, если элементу "Стадия подготовки ЦИМ ОКС" присвоено значение "Стадия "Р"" - элемент обязателен к заполнению
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="elementCode" type="bt:notEmptyString" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            Код элемента
            (Данные должны подтягиваться автоматически в зависимости от значения "Тип элемента")
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ifcCode" type="bt:notEmptyString" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            Класс IFC
            (Данные должны подтягиваться автоматически в зависимости от значения "Тип элемента")
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="ksiCode" type="bt:notEmptyString" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            Код КСИ
            (Данные должны подтягиваться автоматически в зависимости от значения "Тип элемента")
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="msskCode" type="bt:notEmptyString" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            Код МССК
            (Данные должны подтягиваться автоматически в зависимости от значения "Тип элемента")
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="remarkIdInfo">
    <xs:annotation>
      <xs:documentation>Идентификатор замечания</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="sequenceNumber" type="xs:positiveInteger" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Порядковый номер замечания</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="remarkId" type="bt:GUID">
        <xs:annotation>
          <xs:documentation>ID замечания</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="defectBaseInfo">
    <xs:annotation>
      <xs:documentation>
        Тип, содержащий общую информацию о выявленном/устраненном недостатке, включая атрибуты и подпись сотрудника, проводившего контроль
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="defectInfoSignedPart">
        <xs:annotation>
          <xs:documentation>Подписываемая часть информации о выявленном/устраненном недостатке</xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element name="defectRecordId" type="bt:GUID">
              <xs:annotation>
                <xs:documentation>ID записи о выявленном недостатке результатов работ</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="defectRecordDate" type="xs:date">
              <xs:annotation>
                <xs:documentation>Дата внесения записи о недостатке</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="defectNumber" type="xs:positiveInteger">
              <xs:annotation>
                <xs:documentation>Номер недостатка</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="defectControlSubjectDescription" type="cf:subjectDescription" minOccurs="0">
              <xs:annotation>
                <xs:documentation>Описание предмета контроля (работа, ОКС или элемент ОКС)</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="defectDescription" type="cf:defectDescription">
              <xs:annotation>
                <xs:documentation>Описание недостатка</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="defectFixingPlanDate" type="xs:date">
              <xs:annotation>
                <xs:documentation>Установленная (запланированная) дата устранения выявленного недостатка</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="inspectionEmployee" type="cf:representativeWithId">
              <xs:annotation>
                <xs:documentation>Сведения о сотруднике, проводившем контроль</xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
          <xs:attribute name="id" type="bt:GUIDandUnderscore" use="required">
            <xs:annotation>
              <xs:documentation>Id подписываемой части (информация о выявленном/устраненном недостатке)</xs:documentation>
            </xs:annotation>
          </xs:attribute>
        </xs:complexType>
      </xs:element>
      <xs:element name="inspectionEmployeeSignature" type="cf:signature">
        <xs:annotation>
          <xs:documentation>Подпись сотрудника, проводившего контроль</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="fixedDefectInfo">
    <xs:annotation>
      <xs:documentation>
        Информация об устраненном недостатке (с обязательными отметками об ознакомлении с недостатком и обязательными подписями сотрудника (представителя) лица, осуществляющего строительство и представителя застройщика)
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="defectInfoWithBuilderAndDeveloperSignedPart">
        <xs:annotation>
          <xs:documentation>
            Информация о недостатке с обязательной отметкой об ознакомлении с недостатком и обязательной подписью представителя застройщика (подписываемая часть)
          </xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element name="defectInfoWithBuilderSignedPart">
              <xs:annotation>
                <xs:documentation>
                  Информация о недостатке с отметкой об ознакомлении с недостатком представителя лица, осуществляющего строительство (подписываемая часть)
                </xs:documentation>
              </xs:annotation>
              <xs:complexType>
                <xs:complexContent>
                  <xs:extension base="cf:defectBaseInfo">
                    <xs:sequence>
                      <xs:element name="builderRepresentativeFamiliarizationMarkInfo" type="cf:familiarizationMarkInfo" minOccurs="0">
                        <xs:annotation>
                          <xs:documentation>
                            Отметка об ознакомлении со сведениями о недостатке представителя лица, осуществляющего строительство
                          </xs:documentation>
                        </xs:annotation>
                      </xs:element>
                    </xs:sequence>
                    <xs:attribute name="id" type="bt:GUIDandUnderscore" use="required">
                      <xs:annotation>
                        <xs:documentation>
                          Id подписываемой части (информация о недостатке с отметкой об ознакомлении с недостатком представителя лица, осуществляющего строительство)
                        </xs:documentation>
                      </xs:annotation>
                    </xs:attribute>
                  </xs:extension>
                </xs:complexContent>
              </xs:complexType>
            </xs:element>
            <xs:element name="builderRepresentativeSignature" type="cf:signature" minOccurs="0">
              <xs:annotation>
                <xs:documentation>
                  Подпись уполномоченного сотрудника лица, осуществляющего строительство, в отношении которого проведён контроль
                </xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:choice minOccurs="0">
              <xs:element name="developerRepresentativeFamiliarizationMarkInfo" type="cf:familiarizationMarkInfo">
                <xs:annotation>
                  <xs:documentation>
                    Отметка об ознакомлении со сведениями о недостатке представителя застройщика
                  </xs:documentation>
                </xs:annotation>
              </xs:element>
              <xs:element name="technicalCustomerRepresentativeFamiliarizationMarkInfo" type="cf:familiarizationMarkInfo">
                <xs:annotation>
                  <xs:documentation>
                    Отметка об ознакомлении со сведениями о недостатке представителя технического заказчика
                  </xs:documentation>
                </xs:annotation>
              </xs:element>
              <xs:element name="operatingPersonRepresentativeFamiliarizationMarkInfo" type="cf:familiarizationMarkInfo">
                <xs:annotation>
                  <xs:documentation>
                    Отметка об ознакомлении со сведениями о недостатке представителя лица, ответственного за эксплуатацию здания/сооружения
                  </xs:documentation>
                </xs:annotation>
              </xs:element>
              <xs:element name="regionalOperatorRepresentativeFamiliarizationMarkInfo" type="cf:familiarizationMarkInfo">
                <xs:annotation>
                  <xs:documentation>
                    Отметка об ознакомлении со сведениями о недостатке представителя регионального оператора
                  </xs:documentation>
                </xs:annotation>
              </xs:element>
            </xs:choice>
          </xs:sequence>
          <xs:attribute name="id" type="bt:GUIDandUnderscore" use="required">
            <xs:annotation>
              <xs:documentation>
                Id подписываемой части (информация об недостатке с отметкой об ознакомлении с недостатком представителя застройщика)
              </xs:documentation>
            </xs:annotation>
          </xs:attribute>
        </xs:complexType>
      </xs:element>
      <xs:choice minOccurs="0">
        <xs:element name="developerRepresentativeSignature" type="cf:signature">
          <xs:annotation>
            <xs:documentation>Подпись уполномоченного сотрудника застройщика</xs:documentation>
          </xs:annotation>
        </xs:element>
        <xs:element name="technicalCustomerRepresentativeSignature" type="cf:signature">
          <xs:annotation>
            <xs:documentation>Подпись уполномоченного сотрудника техического заказчика</xs:documentation>
          </xs:annotation>
        </xs:element>
        <xs:element name="operatingPersonRepresentativeSignature" type="cf:signature">
          <xs:annotation>
            <xs:documentation>
              Подпись уполномоченного сотрудника лица, ответственного за эксплуатацию здания/сооружения
            </xs:documentation>
          </xs:annotation>
        </xs:element>
        <xs:element name="regionalOperatorRepresentativeSignature" type="cf:signature">
          <xs:annotation>
            <xs:documentation>Подпись уполномоченного сотрудника регионального оператора</xs:documentation>
          </xs:annotation>
        </xs:element>
      </xs:choice>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="subjectDescription">
    <xs:annotation>
      <xs:documentation>Описание предмета контроля (работа, ОКС или элемент ОКС)</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="structuralElement">
        <xs:annotation>
          <xs:documentation>Структурный элемент</xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element name="structuralElementId" type="bt:GUID" minOccurs="0">
              <xs:annotation>
                <xs:documentation>id расположения структурного элемента в иерархии</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="structuralElementName" type="bt:notEmptyString">
              <xs:annotation>
                <xs:documentation>Наименование и обозначение структурного элемента</xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="worksResultsLocation" type="cf:location">
        <xs:annotation>
          <xs:documentation>Местоположение результатов работ</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="workList" type="cf:workList" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Список работ в отношении структурного элемента и результата работ в указанном месторасположении</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="defectDescription">
    <xs:annotation>
      <xs:documentation>Описание недостатка</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="defectDescriptionText" type="bt:notEmptyString">
        <xs:annotation>
          <xs:documentation>Формулировка выявленного недостатка</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="technicalRegulationsList">
        <xs:annotation>
          <xs:documentation>
            Перечень технических регламентов, иных нормативных правовых актов, требования которых нарушены
          </xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element name="technicalRegulationsListItem" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>
                  Технический регламент, иной нормативный правовой акт, требования которого нарушены
                </xs:documentation>
              </xs:annotation>
              <xs:complexType>
                <xs:complexContent>
                  <xs:extension base="cf:docInfo">
                    <xs:sequence>
                      <xs:element name="technicalRegulationsSectionsList" minOccurs="0">
                        <xs:annotation>
                          <xs:documentation>
                            Перечень структурных единиц технического регламента, иного нормативно-правового акта, требования которых нарушены
                          </xs:documentation>
                        </xs:annotation>
                        <xs:complexType>
                          <xs:sequence>
                            <xs:element name="technicalRegulationsSectionsListItem" type="cf:docInfo" maxOccurs="unbounded">
                              <xs:annotation>
                                <xs:documentation>
                                  Структурная единица технического регламента, иного нормативно-правового акта, требования которого нарушены
                                </xs:documentation>
                              </xs:annotation>
                            </xs:element>
                          </xs:sequence>
                        </xs:complexType>
                      </xs:element>
                    </xs:sequence>
                  </xs:extension>
                </xs:complexContent>
              </xs:complexType>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="projectDocSectionsList" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            Перечень разделов проектной документации, требования которых нарушены
          </xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element name="projectDocSectionsListItem" type="cf:docInfo" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>
                  Раздел проектной документации, требования которого нарушены
                </xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="workingDocSectionsList" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            Перечень разделов рабочей документации, требования которых нарушены
          </xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element name="workingDocSectionsListItem" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>
                  Раздел рабочей документации, требования которого нарушены
                </xs:documentation>
              </xs:annotation>
              <xs:complexType>
                <xs:complexContent>
                  <xs:extension base="cf:docInfo">
                    <xs:sequence>
                      <xs:element name="sheetsNumbersList" minOccurs="0">
                        <xs:annotation>
                          <xs:documentation>
                            Список номеров листов раздела рабочей документации, требования которых нарушены
                          </xs:documentation>
                        </xs:annotation>
                        <xs:complexType>
                          <xs:sequence>
                            <xs:element name="sheetsNumbersListItem" type="xs:positiveInteger" maxOccurs="unbounded">
                              <xs:annotation>
                                <xs:documentation>
                                  Номер листа раздела рабочей документации, требования которого нарушены
                                </xs:documentation>
                              </xs:annotation>
                            </xs:element>
                          </xs:sequence>
                        </xs:complexType>
                      </xs:element>
                    </xs:sequence>
                  </xs:extension>
                </xs:complexContent>
              </xs:complexType>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="attachedDocumentsList" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Дополнительные прилагаемые документы (список файлов)</xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element name="attachedDocuments" type="cf:attachedDocuments" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>Информация о документе(документax), загруженном(загруженных) в хранилище</xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="defectConfirmingDocList" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Список документов, подтверждающих факт нарушения</xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element name="defectConfirmingDocListItem" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>Документ, подтверждающий факт нарушения</xs:documentation>
              </xs:annotation>
              <xs:complexType>
                <xs:choice>
                  <xs:element name="executiveSchemeOrDrawing">
                    <xs:annotation>
                      <xs:documentation>Исполнительная схема или чертёж</xs:documentation>
                    </xs:annotation>
                    <xs:complexType>
                      <xs:sequence>
                        <xs:group ref="cf:docInfoGroup">
                          <xs:annotation>
                            <xs:documentation>Наименование и номер документа</xs:documentation>
                          </xs:annotation>
                        </xs:group>
                        <xs:element name="date" type="xs:date" minOccurs="0">
                          <xs:annotation>
                            <xs:documentation>Дата</xs:documentation>
                          </xs:annotation>
                        </xs:element>
                        <xs:element name="docId" type="bt:GUID">
                          <xs:annotation>
                            <xs:documentation>Id документа</xs:documentation>
                          </xs:annotation>
                        </xs:element>
                      </xs:sequence>
                    </xs:complexType>
                  </xs:element>
                  <xs:element name="anotherDoc">
                    <xs:annotation>
                      <xs:documentation>Иной документ, который подтверждает факт нарушения</xs:documentation>
                    </xs:annotation>
                    <xs:complexType>
                      <xs:sequence>
                        <xs:group ref="cf:docInfoGroup">
                          <xs:annotation>
                            <xs:documentation>Наименование и номер документа</xs:documentation>
                          </xs:annotation>
                        </xs:group>
                        <xs:element name="carrierId">
                          <xs:annotation>
                            <xs:documentation>Идентификатор носителя документа</xs:documentation>
                          </xs:annotation>
                          <xs:complexType>
                            <xs:sequence>
                              <xs:choice>
                                <xs:element name="docId" type="bt:GUID">
                                  <xs:annotation>
                                    <xs:documentation>Id документа</xs:documentation>
                                  </xs:annotation>
                                </xs:element>
                                <xs:element name="attachedDocuments" type="cf:attachedDocuments">
                                  <xs:annotation>
                                    <xs:documentation>Информация о документе(документax), загруженном(загруженных) в хранилище</xs:documentation>
                                  </xs:annotation>
                                </xs:element>
                              </xs:choice>
                            </xs:sequence>
                          </xs:complexType>
                        </xs:element>
                      </xs:sequence>
                    </xs:complexType>
                  </xs:element>
                  <xs:element name="resultsDoc">
                    <xs:annotation>
                      <xs:documentation>
                        Документ с результатами экспертиз, обследований, лабораторных и иных испытаний выполненных работ, проведенных в процессе строительного контроля
                      </xs:documentation>
                    </xs:annotation>
                    <xs:complexType>
                      <xs:complexContent>
                        <xs:extension base="cf:docNameAndNumberAndDate">
                          <xs:sequence>
                            <xs:element name="testingName" type="bt:notEmptyString">
                              <xs:annotation>
                                <xs:documentation>Наименование экспертизы, обследования, испытания и т.п.</xs:documentation>
                              </xs:annotation>
                            </xs:element>
                          </xs:sequence>
                        </xs:extension>
                      </xs:complexContent>
                    </xs:complexType>
                  </xs:element>
                </xs:choice>
              </xs:complexType>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="workList">
    <xs:annotation>
      <xs:documentation>
        Список работ в отношении структурного элемента и результатов работ в указанном месторасположении
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="workListItem" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>
            Работа в отношении структурного элемента и результаты работ в указанном месторасположении
          </xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element name="workId" type="bt:GUID" minOccurs="0">
              <xs:annotation>
                <xs:documentation>id работы</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="workName" type="bt:notEmptyString">
              <xs:annotation>
                <xs:documentation>Наименование работы</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="workJournalsRecordsList" minOccurs="0">
              <xs:annotation>
                <xs:documentation>Список записей журналов работ, содержащих сведения о работе</xs:documentation>
              </xs:annotation>
              <xs:complexType>
                <xs:sequence>
                  <xs:element name="workJournalsRecordsListItem" maxOccurs="unbounded">
                    <xs:annotation>
                      <xs:documentation>Запись журнала работ со сведениями о конкретной работе</xs:documentation>
                    </xs:annotation>
                    <xs:complexType>
                      <xs:sequence>
                        <xs:element name="generalWorkJournalRecordId" type="bt:GUID">
                          <xs:annotation>
                            <xs:documentation>Идентификатор записи работы в общем журнале работ</xs:documentation>
                          </xs:annotation>
                        </xs:element>
                        <xs:element name="specialWorkJournalRecordId" type="bt:GUID" minOccurs="0">
                          <xs:annotation>
                            <xs:documentation>Идентификатор записи работы в специальном журнале работ</xs:documentation>
                          </xs:annotation>
                        </xs:element>
                      </xs:sequence>
                    </xs:complexType>
                  </xs:element>
                </xs:sequence>
              </xs:complexType>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="permanentObjectParameters">
    <xs:annotation>
      <xs:documentation>Характеристики объекта капитального строительства</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="sequenceNumber" type="xs:positiveInteger">
        <xs:annotation>
          <xs:documentation>Порядковый номер объекта капитального строительства</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="structureElementId" type="bt:GUID" minOccurs="0">
        <xs:annotation>
          <xs:documentation>id структурного элемента</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="permanentObjectTypeInfo">
        <xs:annotation>
          <xs:documentation>Здание или строение/сооружение</xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:choice>
            <xs:element name="building">
              <xs:annotation>
                <xs:documentation>Здание</xs:documentation>
              </xs:annotation>
              <xs:complexType>
                <xs:sequence>
                  <xs:element name="permanentObjectName" type="bt:notEmptyString" minOccurs="0">
                    <xs:annotation>
                      <xs:documentation>Наименование здания, являющегося частью сложного объекта</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="permanentObjectType">
                    <xs:annotation>
                      <xs:documentation>
                        Вид объекта капитального строительства
                        Допустимые значения:
                        - Здание
                      </xs:documentation>
                    </xs:annotation>
                    <xs:simpleType>
                      <xs:restriction base="bt:notEmptyString">
                        <xs:enumeration value="Здание" />
                      </xs:restriction>
                    </xs:simpleType>
                  </xs:element>
                  <xs:element name="permanentObjectAssignment">
                    <xs:annotation>
                      <xs:documentation>
                        Назначение объекта
                        Допустимые значения:
                        - нежилое здание
                        - многоквартирный дом
                        - жилой дом
                        - садовый дом
                        - гараж
                      </xs:documentation>
                    </xs:annotation>
                    <xs:simpleType>
                      <xs:restriction base="bt:notEmptyString">
                        <xs:enumeration value="нежилое здание" />
                        <xs:enumeration value="многоквартирный дом" />
                        <xs:enumeration value="жилой дом" />
                        <xs:enumeration value="садовый дом" />
                        <xs:enumeration value="гараж" />
                      </xs:restriction>
                    </xs:simpleType>
                  </xs:element>
                </xs:sequence>
              </xs:complexType>
            </xs:element>
            <xs:element name="structure">
              <xs:annotation>
                <xs:documentation>Строение/Сооружение</xs:documentation>
              </xs:annotation>
              <xs:complexType>
                <xs:sequence>
                  <xs:element name="permanentObjectName" type="bt:notEmptyString" minOccurs="0">
                    <xs:annotation>
                      <xs:documentation>Наименование строения, сооружения являющегося частью сложного объекта</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                  <xs:element name="permanentObjectType">
                    <xs:annotation>
                      <xs:documentation>
                        Вид объекта капитального строительства
                        Допустимые значения:
                        - строение
