                  <xs:element name="asBuiltSchemasListItem" type="cf:docNameAndNumberAndDate" maxOccurs="unbounded">
                    <xs:annotation>
                      <xs:documentation>Исполнительная схема / чертеж</xs:documentation>
                    </xs:annotation>
                  </xs:element>
                </xs:sequence>
              </xs:complexType>
            </xs:element>
            <xs:element name="examinationResultDocumentsList" minOccurs="0">
