  <xs:complexType name="authorizationDocument">
    <xs:annotation>
      <xs:documentation>
        Документ, подтверждающий право выполнять определённый вид деятельности
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="documentRequisites" type="cf:docBaseInfoWithOptionalExpirationDate">
        <xs:annotation>
          <xs:documentation>Реквизиты документа</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="activityName" type="bt:notEmptyString" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Наименование деятельности, на которую оформлен документ</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="documentIssuingOrganization" type="cf:legalEntity">
        <xs:annotation>
          <xs:documentation>Сведения об организации, выдавшей документ</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="normativeLegalAct">
        <xs:annotation>
          <xs:documentation>Нормативно-правовой акт, на основании которого выдан документ</xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element name="actLabel" type="bt:notEmptyString">
              <xs:annotation>
                <xs:documentation>Обозначение акта</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="actName" type="bt:notEmptyString">
              <xs:annotation>
                <xs:documentation>Наименование акта</xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="attachedDocuments" type="cf:attachedDocuments">
        <xs:annotation>
          <xs:documentation>Информация о файлах, относящихся к документу</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="standardArchitecturalProposal">
    <xs:annotation>
      <xs:documentation>
        Типовое архитектурное решение объекта капитального строительства, утвержденное для исторического поселения
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:group ref="cf:docNameAndNumberAndDateGroupWithoutId">
        <xs:annotation>
          <xs:documentation>
            Информация о документе, включающая:
            - Наименование
            - Номер/код/шифр
            - Дата выдачи
          </xs:documentation>
        </xs:annotation>
      </xs:group>
      <xs:element name="authorityName" type="bt:notEmptyString">
        <xs:annotation>
          <xs:documentation>Наименование уполномоченного органа</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="docNumberAndDateAndAuthorityName">
    <xs:annotation>
      <xs:documentation>
        Информация о документе, включающая:
        - Номер/код/шифр
        - Дата выдачи
        - Наименование уполномоченной организации / уполномоченного лица
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="cf:docNumberAndDate">
        <xs:sequence>
          <xs:element name="authorityName" type="bt:notEmptyString">
            <xs:annotation>
              <xs:documentation>
                Наименование уполномоченной организации / уполномоченного лица
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="docNumberAndDateAndAuthorityNameAndSequenceNumber">
    <xs:annotation>
      <xs:documentation>
        Информация о документе, включающая:
        - Номер/код/шифр
        - Дата выдачи
        - Наименование уполномоченной организации / уполномоченного лица
        - Порядковый номер
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="cf:docNumberAndDate">
        <xs:sequence>
          <xs:element name="authorityName" type="bt:notEmptyString">
            <xs:annotation>
              <xs:documentation>
                Наименование уполномоченной организации / уполномоченного лица
              </xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="sequenceNumber" type="xs:positiveInteger">
            <xs:annotation>
              <xs:documentation>Порядковый номер</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="projectDocSectionsList">
    <xs:annotation>
      <xs:documentation>Разделы проектной документации (сокр.) (список)</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="projectDocSectionsListItem" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>Раздел проектной документации (сокр.)</xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:complexContent>
            <xs:extension base="cf:docInfo">
              <xs:sequence>
                <xs:element name="projectDocSectionId" type="bt:GUID" minOccurs="0">
                  <xs:annotation>
                    <xs:documentation>ID раздела</xs:documentation>
                  </xs:annotation>
                </xs:element>
              </xs:sequence>
            </xs:extension>
          </xs:complexContent>
        </xs:complexType>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="projDocSectionList">
    <xs:annotation>
      <xs:documentation>Список разделов проектной документации</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="projDocSection" type="cf:documentationSectionInfo" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>Раздел проектной документации</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="workDocSectionList">
    <xs:annotation>
      <xs:documentation>Список разделов рабочей документации</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="workDocSection" type="cf:documentationSectionInfo" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>Раздел рабочей документации</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="documentDetails">
    <xs:annotation>
      <xs:documentation>
        Информация о документе, включающая:
        - Наименование
        - Номер/код/шифр
        - Дата выдачи
        - ID документа
        - Номер дела (необяз.)
        - ID дела (необяз.)
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="cf:docNameAndNumberAndDate">
        <xs:sequence>
          <xs:element name="caseNumber" type="bt:notEmptyString" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Номер дела</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="caseId" type="bt:GUID" minOccurs="0">
            <xs:annotation>
              <xs:documentation>ID дела</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="journalRequisites">
    <xs:annotation>
      <xs:documentation>Реквизиты документа (журнала)</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="docId" type="bt:GUID">
        <xs:annotation>
          <xs:documentation>ID документа</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="name" type="bt:notEmptyString">
        <xs:annotation>
          <xs:documentation>Наименование документа</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="number" type="bt:notEmptyString" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Номер документа</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="documentEdition" type="xs:positiveInteger">
        <xs:annotation>
          <xs:documentation>Редакция документа (версия)</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="appealBasis">
    <xs:annotation>
      <xs:documentation>Основание жалобы</xs:documentation>
    </xs:annotation>
    <xs:choice>
      <xs:element name="controlEventAct" type="cf:docNameAndNumberAndDate">
        <xs:annotation>
          <xs:documentation>Акт проверки</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="prescript" type="cf:docNameAndNumberAndDate">
        <xs:annotation>
          <xs:documentation>Предписание</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="authoritiesActionsOrInactions">
        <xs:annotation>
          <xs:documentation>Действия/бездействия должностных лиц КНО</xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element name="recordId" type="bt:GUID">
              <xs:annotation>
                <xs:documentation>Идентификатор записи действий/бездействий</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="controlEventName" type="bt:notEmptyString">
              <xs:annotation>
                <xs:documentation>Наименование контрольного (надзорного) мероприятия</xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="actionsOrInactionsDescription" type="bt:notEmptyString">
              <xs:annotation>
                <xs:documentation>Описание действий/бездействий</xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
    </xs:choice>
  </xs:complexType>

  <xs:complexType name="attachedEntitiesList">
    <xs:annotation>
      <xs:documentation>Приложения</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="attachedEntitiesListItem" type="cf:attachedEntity" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>Приложение</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="attachedEntity">
    <xs:annotation>
      <xs:documentation>Приложение</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="attachedEntityNumber" type="xs:positiveInteger" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Порядковый номер</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:choice>
        <xs:element name="attachedEntityDoc" type="cf:docNameAndNumberAndDate">
          <xs:annotation>
            <xs:documentation>Реквизиты документа</xs:documentation>
          </xs:annotation>
        </xs:element>
        <xs:element name="attachedDocumentsList">
          <xs:annotation>
            <xs:documentation>Дополнительные прилагаемые документы (список файлов)</xs:documentation>
          </xs:annotation>
          <xs:complexType>
            <xs:sequence>
              <xs:element name="attachedDocuments" type="cf:attachedDocuments" maxOccurs="unbounded">
                <xs:annotation>
                  <xs:documentation>Информация о файлах, относящихся к документу</xs:documentation>
                </xs:annotation>
              </xs:element>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
      </xs:choice>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="emailSendingInfo">
    <xs:annotation>
      <xs:documentation>Информация о направлении документа на электронную почту</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="emailSendingMark" type="bt:notEmptyString">
        <xs:annotation>
          <xs:documentation>Отметка о направлении документа на почту</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="emailSendingDate" type="xs:date">
        <xs:annotation>
          <xs:documentation>Дата направления</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="email" type="bt:notEmptyString">
        <xs:annotation>
          <xs:documentation>Адрес электронной почты</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>
  <!-- Типы и группы, содержащие информацию о документе и файле (end) -->

  <!-- Тип, содержащий информацию о файле из файлового хранилища (start) -->
  <xs:complexType name="attachedDocuments">
    <xs:annotation>
      <xs:documentation>Документ с внутренней и/или откреплённой подписью</xs:documentation>
    </xs:annotation>
    <xs:choice>
      <xs:element name="variantRequiredFileWithInternalSignature">
        <xs:annotation>
          <xs:documentation>
            Вариант с обязательным элементом "Документ с внутренней подписью"
          </xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element name="fileWithInternalSignature" type="cf:fileWithInternalSignature">
              <xs:annotation>
                <xs:documentation>
                  Документ с внутренней подписью
                  Заполняется в случаях, если передается:
                  1. файл документа, подписанный внутренними подписями
                  2. файл копии документа заверенная ("копия верна") внутренней подписью
                </xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="fileWithDisattachSignature" type="cf:fileWithDisattachSignature" minOccurs="0">
              <xs:annotation>
                <xs:documentation>
                  Документ с откреплённой подписью / Документ без подписей
                  Заполняется в случае:
                  1. если документ подписан  открепленной подписью и передается  файл документа
                  и файлы(.sig) открепленных подписей  подписантов
                  2. если файл передаваемого документа не требует подписания
                </xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="variantRequiredFileWithDisattachSignature">
        <xs:annotation>
          <xs:documentation>
            Вариант с обязательным элементом "Документ с откреплённой подписью / Документ без подписей"
          </xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element name="fileWithDisattachSignature" type="cf:fileWithDisattachSignature">
              <xs:annotation>
                <xs:documentation>
                  Документ с откреплённой подписью / Документ без подписей
                  Заполняется в случае:
                  1. если документ подписан  открепленной подписью и передается  файл документа
                  и файлы(.sig) открепленных подписей  подписантов
                  2. если файл передаваемого документа не требует подписания
                </xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
    </xs:choice>
  </xs:complexType>

  <xs:complexType name="fileWithInternalSignature">
    <xs:annotation>
      <xs:documentation>Документ с внутренней подписью</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="file" type="cf:attachedFile">
        <xs:annotation>
          <xs:documentation>Файл в хранилище</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="personsWithMchdList" minOccurs="0">
        <xs:annotation>
          <xs:documentation>
            Подписант + МЧД (список)
            Заполняется в случае, если документ подписан внутренними подписями ФЛ (не руководитель) и/или подписант в проекте является представителем одного из участников ЖЦ ОКС 
          </xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element name="personsWithMchd" type="cf:personIdAndMchd" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>Подписант + МЧД (элемент списка)</xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="personIdAndMchd">
    <xs:annotation>
      <xs:documentation>Подписант + МЧД</xs:documentation>
    </xs:annotation>
    <xs:choice>
      <xs:element name="variantRequiredPersonId">
        <xs:annotation>
          <xs:documentation>
            Вариант с обязательным элементом "ID подписанта"
          </xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element name="personId" type="bt:GUID">
              <xs:annotation>
                <xs:documentation>
                  ID подписанта
                  - Заполняется в случае, если подписант в проекте является представителем одного из участников ЖЦ ОКС
                  - Не заполняется, если подписантом является внешний по отношению к проекту ЮЛ или ФЛ  
                </xs:documentation>
              </xs:annotation>
            </xs:element>
            <xs:element name="personMchd" type="cf:personMchd" minOccurs="0">
              <xs:annotation>
                <xs:documentation>
                  МЧД подписанта
                  Заполняется в случае, если документ подписан подписантом подписью ФЛ (не руководитель)  
                </xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
      <xs:element name="variantRequiredPersonMchd">
        <xs:annotation>
          <xs:documentation>
            Вариант с обязательным элементом "МЧД подписанта"
          </xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element name="personMchd" type="cf:personMchd">
              <xs:annotation>
                <xs:documentation>
                  МЧД подписанта
                  Заполняется в случае, если документ подписан подписантом подписью ФЛ (не руководитель)  
                </xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
    </xs:choice>
  </xs:complexType>

  <xs:complexType name="personIdAndMchdAndSignatureFile">
    <xs:annotation>
      <xs:documentation>Подписант (ID) + подпись + МЧД</xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="cf:personIdAndMchd">
        <xs:sequence>
          <xs:element name="signatureFile" type="cf:attachedFile">
            <xs:annotation>
              <xs:documentation>
                Подпись подписанта (откреплённая)
                Заполняется информацией о загруженном в ФХ файле открепленной подписи.  
              </xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="fileWithDisattachSignature">
    <xs:annotation>
      <xs:documentation>Документ с откреплённой подписью / Документ без подписей</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="file" type="cf:attachedFile">
        <xs:annotation>
          <xs:documentation>Файл в хранилище</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="personsWithMchdAndSignatureList" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Подписант + подпись + МЧД (список)</xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element
              name="personsWithMchdAndSignature"
              type="cf:personIdAndMchdAndSignatureFile"
              maxOccurs="unbounded"
            >
              <xs:annotation>
                <xs:documentation>Подписант + подпись + МЧД (элемент списка)</xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="personMchd">
    <xs:annotation>
      <xs:documentation>МЧД подписанта</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="mchdId" type="bt:GUID">
        <xs:annotation>
          <xs:documentation>Единый регистрационный номер доверенности (МЧД)</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="principalInn" type="bt:inn">
        <xs:annotation>
          <xs:documentation>ИНН доверителя</xs:documentation>
        </xs:annotation>
      </xs:element>
