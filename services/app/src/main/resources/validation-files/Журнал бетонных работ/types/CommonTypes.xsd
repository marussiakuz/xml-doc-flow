          <xs:documentation>Дата составления акта</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="edition" type="xs:positiveInteger">
        <xs:annotation>
          <xs:documentation>Редакция документа (версия)</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="documentationSectionInfo">
    <xs:annotation>
      <xs:documentation>Идентификатор документа ПИР</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="documentationCode" type="bt:notEmptyString">
        <xs:annotation>
          <xs:documentation>Шифр</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="documentationName" type="bt:notEmptyString">
        <xs:annotation>
          <xs:documentation>Наименование</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="documentationId" type="bt:GUID">
        <xs:annotation>
          <xs:documentation>ID раздела/основного комплекта/документа</xs:documentation>
        </xs:annotation>
