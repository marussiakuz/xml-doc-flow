<?xml version="1.0" encoding="utf-8" ?>
<xs:schema
  targetNamespace="http://v_17_0/types/CommonTypes.xsd"
  elementFormDefault="qualified"
  xmlns:xs="http://www.w3.org/2001/XMLSchema"
  xmlns:cf="http://v_17_0/types/CommonTypes.xsd"
  xmlns:bt="http://v_17_0/types/BaseTypes.xsd"
  xmlns:sg="http://www.w3.org/2000/09/xmldsig#"
>
  <!-- Импорты внешних зависимостей -->
  <xs:import schemaLocation="./BaseTypes.xsd" namespace="http://v_17_0/types/BaseTypes.xsd" />
  <xs:import schemaLocation="../types/Xmldsig.xsd" namespace="http://www.w3.org/2000/09/xmldsig#" />

  <!-- Тип, содержащий информацию о внутренней подписи (start) -->
  <xs:complexType name="signature">
    <xs:annotation>
      <xs:documentation>Подпись (УКЭП)</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element ref="sg:Signature">
        <xs:annotation>
          <xs:documentation>Параметры УКЭП</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="personId" type="bt:GUID">
        <xs:annotation>
          <xs:documentation>ID подписанта</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="mchdId" type="bt:GUID" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Единый регистрационный номер доверенности (МЧД)</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>
  <!-- Тип, содержащий информацию о внутренней подписи (end) -->

  <!-- Типы и группы, содержащие информацию о документе (start) -->
  <xs:group name="docInfoGroup">
    <xs:annotation>
      <xs:documentation>
        Информация о документе, включающая:
        - Наименование
        - Номер/код/шифр
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="name" type="bt:notEmptyString">
        <xs:annotation>
          <xs:documentation>Наименование документа</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="number" type="bt:notEmptyString">
        <xs:annotation>
          <xs:documentation>Номер/код/шифр документа</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:group>

  <xs:complexType name="docInfo">
    <xs:annotation>
      <xs:documentation>
        Информация о документе, включающая:
        - Наименование
        - Номер/код/шифр
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:group ref="cf:docInfoGroup" />
    </xs:sequence>
  </xs:complexType>

  <xs:group name="docNumberAndDateGroup">
    <xs:annotation>
      <xs:documentation>
        Информация о документе, включающая:
        - Номер/код/шифр
        - Дата выдачи
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="number" type="bt:notEmptyString">
        <xs:annotation>
          <xs:documentation>Номер/код/шифр документа</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="date" type="xs:date">
        <xs:annotation>
          <xs:documentation>Дата документа</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:group>

  <xs:complexType name="docNumberAndDate">
    <xs:annotation>
      <xs:documentation>
        Информация о документе, включающая:
        - Номер/код/шифр
        - Дата выдачи
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:group ref="cf:docNumberAndDateGroup" />
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="docNameAndDate">
    <xs:annotation>
      <xs:documentation>
        Информация о документе, включающая:
        - Наименование
        - Дата выдачи
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="name" type="bt:notEmptyString">
        <xs:annotation>
          <xs:documentation>Наименование</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="date" type="xs:date">
        <xs:annotation>
          <xs:documentation>Дата документа</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:group name="docNumberAndDateGroupWithId">
    <xs:annotation>
      <xs:documentation>
        Информация о документе, включающая:
        - Номер/код/шифр
        - Дата выдачи
        - ID документа
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="number" type="bt:notEmptyString">
        <xs:annotation>
          <xs:documentation>Номер или код или шифр документа</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="date" type="xs:date">
        <xs:annotation>
          <xs:documentation>Дата документа</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="docId" type="bt:GUID">
        <xs:annotation>
          <xs:documentation>ID документа</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:group>

  <xs:complexType name="docNumberAndDateAndId">
    <xs:annotation>
      <xs:documentation>
        Информация о документе, включающая:
        - Номер/код/шифр
        - Дата выдачи
        - ID документа
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:group ref="cf:docNumberAndDateGroupWithId" />
    </xs:sequence>
  </xs:complexType>

  <xs:group name="docNameAndNumberAndDateGroupWithoutId">
    <xs:annotation>
      <xs:documentation>
        Информация о документе, включающая:
        - Наименование
        - Номер/код/шифр
        - Дата выдачи
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:group ref="cf:docInfoGroup">
        <xs:annotation>
          <xs:documentation>
            Информация о документе, включающая:
            - Наименование
            - Номер/код/шифр
          </xs:documentation>
        </xs:annotation>
      </xs:group>
      <xs:element name="date" type="xs:date">
        <xs:annotation>
          <xs:documentation>Дата документа</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:group>

  <xs:complexType name="docBaseInfo">
    <xs:annotation>
      <xs:documentation>
        Информация о документе, включающая:
        - Наименование
        - Номер/код/шифр
        - Дата выдачи
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:group ref="cf:docNameAndNumberAndDateGroupWithoutId" />
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="docBaseInfoWithFile">
    <xs:annotation>
      <xs:documentation>
        Информация о документе, включающая:
        - Наименование
        - Номер/код/шифр
        - Дата выдачи
        - Информация о файле, загруженном в хранилище
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="cf:docBaseInfo">
        <xs:sequence>
          <xs:element name="attachedDocuments" type="cf:attachedDocuments">
            <xs:annotation>
              <xs:documentation>Информация о файлах, относящихся к документу</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="docBaseInfoWithOptionalFileAndOptionalId">
    <xs:annotation>
      <xs:documentation>
        Информация о документе, включающая:
        - Наименование
        - Номер/код/шифр
        - Дата выдачи
        - ID документа (необяз.)
        - Информация о файле, загруженном в хранилище (необяз.)
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="cf:docBaseInfo">
        <xs:sequence>
          <xs:element name="docId" type="bt:GUID" minOccurs="0">
            <xs:annotation>
              <xs:documentation>ID документа</xs:documentation>
            </xs:annotation>
          </xs:element>
          <xs:element name="attachedDocuments" type="cf:attachedDocuments" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Информация о файлах, относящихся к документу</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="docBaseInfoWithFileAndOptionalExpirationDate">
    <xs:annotation>
      <xs:documentation>
        Информация о документе, включающая:
        - Наименование
        - Номер/код/шифр
        - Дата выдачи
        - Информация о файле, загруженном в хранилище
        - Дата окончания (необяз.)
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="cf:docBaseInfoWithFile">
        <xs:sequence>
          <xs:element name="expirationDate" type="xs:date" minOccurs="0">
            <xs:annotation>
              <xs:documentation>Дата окончания (срок действия)</xs:documentation>
            </xs:annotation>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="executiveAuthorityDocInfo">
    <xs:annotation>
      <xs:documentation>
        Сведения о документе, выданном органом власти
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="docDetails" type="cf:docDetailsWithExpirationDateAndDocChangeDate">
        <xs:annotation>
          <xs:documentation>
            Реквизиты документа, со сроком действия и датой изменения
          </xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="executiveAuthorityId" type="bt:GUID" minOccurs="0">
        <xs:annotation>
          <xs:documentation>ID органа исполнительной власти</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="executiveAuthorityName" type="bt:notEmptyString">
        <xs:annotation>
          <xs:documentation>
            Наименование органа исполнительной власти или органа местного самоуправления, выдавшего документ
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="authorityDocInfo">
      <xs:annotation>
        <xs:documentation>
          Сведения о документе, выданном органом власти
        </xs:documentation>
      </xs:annotation>
      <xs:sequence>
        <xs:element name="docDetails" type="cf:docDetailsWithExpirationDateAndDocChangeDate">
          <xs:annotation>
            <xs:documentation>
              Реквизиты документа, со сроком действия и датой изменения
            </xs:documentation>
          </xs:annotation>
        </xs:element>
        <xs:element name="participantAuthorityId" type="bt:GUID" minOccurs="0">
          <xs:annotation>
            <xs:documentation>
              ID органа исполнительной власти, выдавшего документ (если он является участником ЖЦ ОКС)
            </xs:documentation>
          </xs:annotation>
        </xs:element>
        <xs:element name="authorityName" type="bt:notEmptyString">
          <xs:annotation>
            <xs:documentation>
              Наименование органа исполнительной власти или органа местного самоуправления (организации), выдавшего документ
            </xs:documentation>
          </xs:annotation>
        </xs:element>
      </xs:sequence>
    </xs:complexType>

  <xs:complexType name="docBaseInfoWithOptionalExpirationDate">
    <xs:annotation>
      <xs:documentation>
        Информация о документе, включающая:
        - Наименование
        - Номер/код/шифр
        - Дата выдачи
        - Дата окончания (необяз.)
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:group ref="cf:docNameAndNumberAndDateGroupWithoutId">
        <xs:annotation>
          <xs:documentation>
            Информация о документе, включающая:
            - Наименование
            - Номер/код/шифр
            - Дата выдачи
          </xs:documentation>
        </xs:annotation>
      </xs:group>
      <xs:element name="expirationDate" type="xs:date" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Дата окончания (cрок действия)</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="docBaseInfoWithExpirationDate">
    <xs:annotation>
      <xs:documentation>
        Информация о документе, включающая:
        - Наименование
        - Номер/код/шифр
        - Дата выдачи
        - Дата окончания
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:group ref="cf:docNameAndNumberAndDateGroupWithoutId">
        <xs:annotation>
          <xs:documentation>
            Информация о документе, включающая:
            - Наименование
            - Номер/код/шифр
            - Дата выдачи
          </xs:documentation>
        </xs:annotation>
      </xs:group>
      <xs:element name="expirationDate" type="xs:date">
        <xs:annotation>
          <xs:documentation>Дата окончания (cрок действия)</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:group name="docNameAndNumberAndDateGroup">
    <xs:annotation>
      <xs:documentation>
        Информация о документе, включающая:
        - Наименование
        - Номер/код/шифр
        - Дата выдачи
        - ID документа
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:group ref="cf:docInfoGroup">
        <xs:annotation>
          <xs:documentation>
            Информация о документе, включающая:
            - Наименование
            - Номер/код/шифр
          </xs:documentation>
        </xs:annotation>
      </xs:group>
      <xs:element name="date" type="xs:date">
        <xs:annotation>
          <xs:documentation>Дата документа</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="docId" type="bt:GUID">
        <xs:annotation>
          <xs:documentation>ID документа</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:group>

  <xs:complexType name="docNameAndNumberAndDate">
    <xs:annotation>
      <xs:documentation>
        Информация о документе, включающая:
        - Наименование
        - Номер/код/шифр
        - Дата выдачи
        - ID документа
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:group ref="cf:docNameAndNumberAndDateGroup" />
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="docNameAndNumberAndDateWithOptionalId">
    <xs:annotation>
      <xs:documentation>
        Информация о документе, включающая:
        - Наименование
        - Номер/код/шифр
        - Дата выдачи
        - ID документа (необяз.)
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:group ref="cf:docInfoGroup">
        <xs:annotation>
          <xs:documentation>
            Информация о документе, включающая:
            - Наименование
            - Номер/код/шифр
          </xs:documentation>
        </xs:annotation>
      </xs:group>
      <xs:element name="date" type="xs:date">
        <xs:annotation>
          <xs:documentation>Дата документа</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="docId" type="bt:GUID" minOccurs="0">
        <xs:annotation>
          <xs:documentation>ID документа</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="ntd">
    <xs:annotation>
      <xs:documentation>
        Перечень технических регламентов, иных НПА и их структурных единиц
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="technicalRegulationDetailsList">
        <xs:annotation>
          <xs:documentation>
            Реквизиты технических регламентов, иных нормативно-правовых актов
          </xs:documentation>
        </xs:annotation>
        <xs:complexType>
          <xs:sequence>
            <xs:element name="technicalRegulationDetailsListItem" maxOccurs="unbounded">
              <xs:annotation>
                <xs:documentation>
                  Реквизиты технического регламента/иного нормативно-правового акта
                </xs:documentation>
              </xs:annotation>
              <xs:complexType>
                <xs:complexContent>
                  <xs:extension base="cf:docInfo">
                    <xs:sequence>
                      <xs:element name="technicalRegulationUnitsList" minOccurs="0">
                        <xs:annotation>
                          <xs:documentation>
                            Реквизиты структурных единиц технических регламентов, иных нормативно-правовых актов
                          </xs:documentation>
                        </xs:annotation>
                        <xs:complexType>
                          <xs:sequence>
                            <xs:element name="technicalRegulationUnitsListItem" type="cf:docInfo" maxOccurs="unbounded">
                              <xs:annotation>
                                <xs:documentation>
                                  Структурная единица технического регламента, иного нормативно-правового акта
                                </xs:documentation>
                              </xs:annotation>
                            </xs:element>
                          </xs:sequence>
                        </xs:complexType>
                      </xs:element>
                    </xs:sequence>
                  </xs:extension>
                </xs:complexContent>
              </xs:complexType>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="regulationDocumentsList">
    <xs:annotation>
      <xs:documentation>Перечень регламентирующих документов (нормативно-правовые акты, технические регламенты и прочие варианты)</xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="regulationDocument" type="cf:regulationDocument" maxOccurs="unbounded">
        <xs:annotation>
          <xs:documentation>
            Регламентирующий документ (нормативно-правовой акт, технический регламент и прочие варианты)
          </xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="regulationDocument">
    <xs:annotation>
      <xs:documentation>
        Регламентирующий документ (нормативно-правовой акт, технический регламент и прочие варианты)
      </xs:documentation>
    </xs:annotation>
    <xs:complexContent>
      <xs:extension base="cf:docInfo">
        <xs:sequence>
          <xs:element name="sectionsList" minOccurs="0">
            <xs:annotation>
              <xs:documentation>
                Перечень структурных единиц регламентирующего документа (секции, статьи, части)
              </xs:documentation>
            </xs:annotation>
            <xs:complexType>
              <xs:sequence>
                <xs:element name="section" type="cf:docInfo" maxOccurs="unbounded">
                  <xs:annotation>
                    <xs:documentation>
                      Структурная единица регламентирующего документа (секции, статьи, части)
                    </xs:documentation>
                  </xs:annotation>
                </xs:element>
              </xs:sequence>
            </xs:complexType>
          </xs:element>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>

  <xs:complexType name="docDetailsWithExpirationDateAndDocChangeDate">
    <xs:annotation>
      <xs:documentation>
        Информация о документе, включающая:
        - Номер/код/шифр
        - Дата выдачи
        - ID документа
        - Дата окончания (необяз.)
        - Дата внесения изменений (необяз.)
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:group ref="cf:docNumberAndDateGroupWithId">
        <xs:annotation>
          <xs:documentation>
            Информация о документе, включающая:
            - Номер/код/шифр
            - Дата выдачи
            - ID документа
          </xs:documentation>
        </xs:annotation>
      </xs:group>
      <xs:element name="expirationDate" type="xs:date" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Дата окончания (Срок действия)</xs:documentation>
        </xs:annotation>
      </xs:element>
      <xs:element name="docChangeDate" type="xs:date" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Дата внесения изменений или исправлений</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="docInfoWithIdAndDate">
    <xs:annotation>
      <xs:documentation>
        Информация о документе, включающая:
        - Наименование
        - Номер/код/шифр
        - Дата выдачи
        - ID документа
        - Дата окончания (необяз.)
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:group ref="cf:docNameAndNumberAndDateGroup">
        <xs:annotation>
          <xs:documentation>
            Информация о документе, включающая:
            - Наименование
            - Номер/код/шифр
            - Дата выдачи
            - ID документа
          </xs:documentation>
        </xs:annotation>
      </xs:group>
      <xs:element name="expirationDate" type="xs:date" minOccurs="0">
        <xs:annotation>
          <xs:documentation>Дата окончания (срок действия)</xs:documentation>
        </xs:annotation>
      </xs:element>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="workAndProjectDocumentation">
    <xs:annotation>
      <xs:documentation>Проектная и рабочая документация</xs:documentation>
    </xs:annotation>
