                <xs:documentation>
                  Подписант документа
                  (В этом элементе передаются ID подписантов Генподрядчика и Застройщика (Генподрядчик задаёт ID подписантов на стороне Застройщика))
                </xs:documentation>
              </xs:annotation>
            </xs:element>
          </xs:sequence>
        </xs:complexType>
      </xs:element>
    </xs:sequence>
